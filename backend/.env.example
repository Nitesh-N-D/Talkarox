# ===========================================
# TALKAROX BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# See SETUP_GUIDE.md in the project root for step-by-step instructions.
# ===========================================

NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ---- Database (Supabase Postgres — free tier) ----
# Get this from: Supabase dashboard > Project Settings > Database > Connection String (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres

# ---- Auth ----
# Any long random string — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# Google OAuth — Google Cloud Console > APIs & Services > Credentials > OAuth Client ID
# Must match the client ID used in frontend/.env (VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ---- Email (Brevo — free tier, no domain required) ----
# Sign up at brevo.com, verify your own email as a sender, then create an API key
BREVO_API_KEY=your-brevo-api-key
SENDER_EMAIL=your-verified-sender@email.com

# ---- AI features (Hugging Face — free inference tier) ----
# Optional: app works with keyword-based fallback if omitted, but for best
# categorization/summarization quality, get a free token at huggingface.co/settings/tokens
HF_API_KEY=your-huggingface-api-key

# ---- File storage (Supabase Storage — same project as your database, free tier) ----
# Get these from: Supabase dashboard > Project Settings > API
# SUPABASE_URL is the "Project URL". SUPABASE_SERVICE_KEY is the "service_role" secret key
# (NOT the anon/public key — the service role key is needed for server-side uploads).
# Buckets named 'avatars', 'attachments', and 'whiteboards' must exist — create them under
# Storage > New bucket, and mark them Public so uploaded files are viewable via URL.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ---- Push notifications (Firebase Cloud Messaging — free tier) ----
# Get these from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# That downloads a JSON file — copy project_id, client_email, and private_key from it.
# IMPORTANT: keep the \n characters literal in FIREBASE_PRIVATE_KEY (don't convert to real newlines).
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
